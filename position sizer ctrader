            Chart.AddControl(_panelHost);
            UpdatePanelVisibility();
            UpdatePanelMinimizeState();
        }

        private TextBlock MakeRowLabel(string text)
        {
            return new TextBlock
            {
                Text = text,
                FontSize = 11,
                ForegroundColor = Color.LightGray,
                Margin = "0 6 0 0"
            };
        }

        private TextBox MakeSmallInput()
        {
            return new TextBox
            {
                Width = 92,
                Height = 24,
                Margin = "0 0 4 0",
                TextAlignment = TextAlignment.Center,
                AcceptsReturn = false
            };
        }

        private void BuildLineTradeButton()
        {
            _lineTradeButton = new Button
            {
                Text = "TRADE",
                Width = 70,
                Height = 26,
                BackgroundColor = Color.OrangeRed,
                ForegroundColor = Color.White,
                IsVisible = false
            };

            _lineTradeButton.Click += args => ExecuteCurrentTradePlan();
            Chart.AddControl(_lineTradeButton, Chart.LastVisibleBarIndex, _entryPrice);
            UpdateLineButtonVisibility();
            UpdateLineTradeButtonPosition();
        }

        private TextBlock MakeText()
        {
            return new TextBlock
            {
                FontSize = 11,
                ForegroundColor = Color.White,
                Margin = "0 1 0 0"
            };
        }

        private void TogglePanelMinimize()
        {
            _isPanelMinimized = !_isPanelMinimized;
            UpdatePanelMinimizeState();
        }

        private void UpdatePanelMinimizeState()
        {
            if (_panelContent != null)
                _panelContent.IsVisible = !_isPanelMinimized;

            if (_minimizeButton != null)
                _minimizeButton.Text = _isPanelMinimized ? "+" : "-";
        }

        private void UpdatePanelVisibility()
        {
            if (_panelHost == null)
                return;

            _panelHost.IsVisible = ShowPanel &&
                                   (ButtonPlacement == TradeButtonPlacement.PanelOnly ||
                                    ButtonPlacement == TradeButtonPlacement.PanelAndLine);
        }

        private void UpdateLineButtonVisibility()
        {
            if (_lineTradeButton == null)
                return;

            _lineTradeButton.IsVisible = ButtonPlacement == TradeButtonPlacement.LineOnly ||
                                         ButtonPlacement == TradeButtonPlacement.PanelAndLine;
        }

        private void SwitchEntryMode()
        {
            if (_entryMode == EntryMode.Instant)
                _entryMode = EntryMode.Pending;
            else if (_entryMode == EntryMode.Pending)
                _entryMode = EntryMode.StopLimit;
            else
                _entryMode = EntryMode.Instant;

            if (_entryMode == EntryMode.Instant)
                _entryPrice = NormalizePrice(InferDirection() == TradeType.Buy ? Symbol.Ask : Symbol.Bid);

            if (_entryLine != null)
                _entryLine.Y = _entryPrice;

            RefreshLineInteractivity();
            RefreshUi();
        }

        private void MarkEditing(ref DateTime editUntil)
        {
            editUntil = DateTime.UtcNow.Add(InputEditLock);
        }

        private bool IsEditing(DateTime editUntil)
        {
            return DateTime.UtcNow < editUntil;
        }

        private void OnEntryInputChanged()
        {
            if (_isSynchronizingInputs || _entryMode == EntryMode.Instant)
                return;

            MarkEditing(ref _entryEditUntil);

            double value;
            if (!TryParseDouble(_entryInput.Text, out value))
                return;

            _entryPrice = NormalizePrice(value);
            if (_entryLine != null)
                _entryLine.Y = _entryPrice;

            RefreshUi();
        }

        private void OnSlInputChanged()
        {
            if (_isSynchronizingInputs)
                return;

            MarkEditing(ref _slEditUntil);

            double value;
            if (!TryParseDouble(_slInput.Text, out value))
                return;

            _slPrice = NormalizePrice(value);
            if (_slLine != null)
                _slLine.Y = _slPrice;

            RefreshUi();
        }

        private void OnTpInputChanged()
        {
            if (_isSynchronizingInputs)
                return;

            MarkEditing(ref _tpEditUntil);

            double value;
            if (!TryParseDouble(_tpInput.Text, out value))
                return;

            _tpPrice = NormalizePrice(value);
            if (_tpLine != null)
                _tpLine.Y = _tpPrice;

            RefreshUi();
        }

        private void OnRiskPercentChanged()
        {
            if (_isSynchronizingInputs)
                return;

            MarkEditing(ref _riskPercentEditUntil);

            double value;
            if (!TryParseDouble(_riskPercentInput.Text, out value))
                return;

            if (value <= 0)
                return;

            _panelRiskPercent = value;
            RefreshUi();
        }

        private void OnMoneyRiskChanged()
        {
            if (_isSynchronizingInputs)
                return;

            MarkEditing(ref _moneyRiskEditUntil);

            double value;
            if (!TryParseDouble(_moneyRiskInput.Text, out value))
                return;

            if (value < 0)
                return;

            _panelMoneyRisk = value;
            RefreshUi();
        }

        private void OnCommissionChanged()
        {
            if (_isSynchronizingInputs)
                return;

            MarkEditing(ref _commissionEditUntil);

            double value;
            if (!TryParseDouble(_commissionInput.Text, out value))
                return;

            if (value < 0)
                return;

            _panelCommissionPerLot = value;
            RefreshUi();
        }

        private bool TryParseDouble(string text, out double value)
        {
            return double.TryParse(text, NumberStyles.Any, CultureInfo.InvariantCulture, out value) ||
                   double.TryParse(text, NumberStyles.Any, CultureInfo.CurrentCulture, out value);
        }

        private void FlipDirection()
        {
            if (_entryMode != EntryMode.Instant)
                SyncFromLines();
            else
            {
                if (_slLine != null)
                    _slPrice = NormalizePrice(_slLine.Y);

                if (_tpLine != null)
                    _tpPrice = NormalizePrice(_tpLine.Y);
            }

            var slPips = GetSlPips();
            var tpPips = GetTpPips();
            var currentDirection = InferDirection();

            if (currentDirection == TradeType.Buy)
            {
                _slPrice = NormalizePrice(_entryPrice + slPips * Symbol.PipSize);
                _tpPrice = NormalizePrice(_entryPrice - tpPips * Symbol.PipSize);
            }
            else
            {
                _slPrice = NormalizePrice(_entryPrice - slPips * Symbol.PipSize);
                _tpPrice = NormalizePrice(_entryPrice + tpPips * Symbol.PipSize);
            }

            if (_slLine != null)
                _slLine.Y = _slPrice;

            if (_tpLine != null)
                _tpLine.Y = _tpPrice;

            RefreshUi();
        }

        private void RefreshUi()
        {
            if (_entryMode != EntryMode.Instant)
            {
                SyncFromLines();
            }
            else
            {
                if (_slLine != null)
                    _slPrice = NormalizePrice(_slLine.Y);

                if (_tpLine != null)
                    _tpPrice = NormalizePrice(_tpLine.Y);
            }

            var direction = InferDirection();
            var slPips = GetSlPips();
            var tpPips = GetTpPips();
            var rr = slPips > 0 ? tpPips / slPips : 0.0;
            var riskAmount = GetRiskAmount();
            var volume = CalculateVolumeInUnits(riskAmount, slPips);

            if (_modeText != null)
                _modeText.Text = $"Mode: {_entryMode}";

            if (_directionText != null)
                _directionText.Text = $"Direction: {direction}";

            if (_riskText != null)
                _riskText.Text = $"Risk: {riskAmount:F2} {Account.Asset.Name} | %: {_panelRiskPercent:F2} | $: {_panelMoneyRisk:F2}";

            if (_volumeText != null)
                _volumeText.Text = $"Volume: {volume:N0}";

            if (_rrText != null)
                _rrText.Text = $"SL {slPips:F1} | TP {tpPips:F1} | RR {rr:F2}";

            if (_statusText != null)
                _statusText.Text = $"{BuildStatusText()} | Spr:{(_panelIncludeSpread ? "On" : "Off")} Com:{(_panelIncludeCommission ? "On" : "Off")}";

            SyncInputsFromState();

            UpdatePanelVisibility();
            UpdatePanelMinimizeState();
            UpdateLineButtonVisibility();
            UpdateLineTradeButtonPosition();
            UpdateChartLabels();
        }

        private void SyncInputsFromState()
        {
            _isSynchronizingInputs = true;

            if (_entryInput != null && !IsEditing(_entryEditUntil))
                _entryInput.Text = FormatPrice(_entryPrice);

            if (_slInput != null && !IsEditing(_slEditUntil))
                _slInput.Text = FormatPrice(_slPrice);

            if (_tpInput != null && !IsEditing(_tpEditUntil))
                _tpInput.Text = FormatPrice(_tpPrice);

            if (_riskPercentInput != null && !IsEditing(_riskPercentEditUntil))
                _riskPercentInput.Text = _panelRiskPercent.ToString("F2", CultureInfo.InvariantCulture);

            if (_moneyRiskInput != null && !IsEditing(_moneyRiskEditUntil))
                _moneyRiskInput.Text = _panelMoneyRisk.ToString("F2", CultureInfo.InvariantCulture);

            if (_commissionInput != null && !IsEditing(_commissionEditUntil))
                _commissionInput.Text = _panelCommissionPerLot.ToString("F2", CultureInfo.InvariantCulture);

            if (_spreadToggleButton != null)
            {
                _spreadToggleButton.Text = _panelIncludeSpread ? "SPR ON" : "SPR OFF";
                _spreadToggleButton.BackgroundColor = _panelIncludeSpread ? Color.SeaGreen : Color.Gray;
            }

            if (_commissionToggleButton != null)
            {
                _commissionToggleButton.Text = _panelIncludeCommission ? "COM ON" : "COM OFF";
                _commissionToggleButton.BackgroundColor = _panelIncludeCommission ? Color.SeaGreen : Color.Gray;
            }

            if (_entryInput != null)
                _entryInput.IsReadOnly = _entryMode == EntryMode.Instant;

            _isSynchronizingInputs = false;
        }

        private void UpdateChartLabels()
        {
            if (!ShowChartLabels)
            {
                Chart.RemoveObject(EntryTextName);
                Chart.RemoveObject(SlTextName);
                Chart.RemoveObject(TpTextName);
                return;
            }

            var direction = InferDirection();
            var slPips = GetSlPips();
            var tpPips = GetTpPips();
            var riskAmount = GetRiskAmount();
            var rewardAmount = slPips > 0 ? riskAmount * (tpPips / slPips) : 0.0;
            var volumeUnits = CalculateVolumeInUnits(riskAmount, slPips);
            var barIndex = Math.Max(Chart.FirstVisibleBarIndex, Chart.LastVisibleBarIndex - 3);

            Chart.DrawText(
                EntryTextName,
                $"{direction} | Entry {FormatPrice(_entryPrice)} | Vol {volumeUnits:N0}",
                barIndex,
                _entryPrice,
                Color.White);

            Chart.DrawText(
                SlTextName,
                $"SL {slPips:F1}p | -{riskAmount:F2} | {FormatPrice(_slPrice)}",
                barIndex,
                _slPrice,
                Color.Red);

            Chart.DrawText(
                TpTextName,
                $"TP {tpPips:F1}p | +{rewardAmount:F2} | {FormatPrice(_tpPrice)}",
                barIndex,
                _tpPrice,
                Color.LimeGreen);
        }

        private void UpdateLineTradeButtonPosition()
        {
            if (_lineTradeButton == null || !_lineTradeButton.IsVisible)
                return;

            var barIndex = Math.Max(Chart.FirstVisibleBarIndex, Chart.LastVisibleBarIndex - 6);
            Chart.MoveControl(_lineTradeButton, barIndex, _entryPrice);
        }

        private string BuildStatusText()
        {
            return ValidateTradePlan(BuildTradePlanFromLines(), false);
        }

        private TradePlan BuildTradePlanFromLines()
        {
            var plan = new TradePlan
            {
                EntryPrice = NormalizePrice(_entryPrice),
                StopLossPrice = NormalizePrice(_slPrice),
                TakeProfitPrice = NormalizePrice(_tpPrice),
                Direction = InferDirection(),
                EntryMode = _entryMode,
                StopLossPips = GetSlPips(),
                TakeProfitPips = GetTpPips(),
                RiskAmount = GetRiskAmount(),
                StopLimitRangePips = _stopLimitRangePips,
                Label = TradeLabel,
                Comment = Commentary
            };

            if (plan.EntryMode == EntryMode.Instant)
                plan.EntryPrice = plan.Direction == TradeType.Buy ? Symbol.Ask : Symbol.Bid;

            plan.VolumeInUnits = CalculateVolumeInUnits(plan.RiskAmount, plan.StopLossPips);
            return plan;
        }

        private string ValidateTradePlan(TradePlan plan, bool strict)
        {
            var spreadPips = Symbol.Spread / Symbol.PipSize;

            if (plan.StopLossPips <= 0)
                return strict ? "Invalid SL distance." : "Status: invalid SL distance";

            if (!DoNotApplyTakeProfit && plan.TakeProfitPips <= 0)
                return strict ? "Invalid TP distance." : "Status: invalid TP distance";

            if (MaxSpreadPips > 0 && spreadPips > MaxSpreadPips)
                return strict ? $"Spread too high: {spreadPips:F1} pips" : $"Status: spread too high ({spreadPips:F1} pips)";

            if (MinEntrySlDistancePips > 0 && plan.StopLossPips < MinEntrySlDistancePips)
                return strict ? "Entry-SL distance below minimum." : "Status: SL distance too small";

            if (MaxEntrySlDistancePips > 0 && plan.StopLossPips > MaxEntrySlDistancePips)
                return strict ? "Entry-SL distance above maximum." : "Status: SL distance too large";

            if (MaxRiskPercentage > 0 && _panelMoneyRisk <= 0 && _panelRiskPercent > MaxRiskPercentage)
                return strict ? "Risk % exceeds max allowed." : "Status: risk % exceeds limit";

            if (plan.VolumeInUnits <= 0)
                return strict ? "Calculated volume is zero." : "Status: zero volume";

            if (plan.EntryMode != EntryMode.Instant)
            {
                var current = plan.Direction == TradeType.Buy ? Symbol.Ask : Symbol.Bid;
                if (Math.Abs(plan.EntryPrice - current) < Symbol.PipSize * 0.1)
                    return strict ? "Pending entry too close to market." : "Status: pending entry too close";
            }

            return strict ? string.Empty : "Status: ready";
        }

        private void ExecuteCurrentTradePlan()
        {
            var plan = BuildTradePlanFromLines();
            var validation = ValidateTradePlan(plan, true);

            if (!string.IsNullOrWhiteSpace(validation))
            {
                Print(validation);
                if (_statusText != null)
                    _statusText.Text = $"Status: {validation}";
                return;
            }

            TradeResult result = null;

            if (plan.EntryMode == EntryMode.Instant)
            {
                result = ExecuteMarketOrder(
                    plan.Direction,
                    SymbolName,
                    plan.VolumeInUnits,
                    plan.Label,
                    DoNotApplyStopLoss ? null : (double?)plan.StopLossPips,
                    DoNotApplyTakeProfit ? null : (double?)plan.TakeProfitPips,
                    plan.Comment,
                    false);
            }
            else if (plan.EntryMode == EntryMode.Pending)
            {
                var current = plan.Direction == TradeType.Buy ? Symbol.Ask : Symbol.Bid;
                var isStop = (plan.Direction == TradeType.Buy && plan.EntryPrice > current) ||
                             (plan.Direction == TradeType.Sell && plan.EntryPrice < current);

                if (isStop)
                {
                    result = PlaceStopOrder(
                        plan.Direction,
                        SymbolName,
                        plan.VolumeInUnits,
                        plan.EntryPrice,
                        plan.Label,
                        DoNotApplyStopLoss ? null : (double?)plan.StopLossPips,
                        DoNotApplyTakeProfit ? null : (double?)plan.TakeProfitPips,
                        ProtectionType.Relative,
                        GetExpiry(),
                        plan.Comment,
                        false,
                        StopTriggerMethod.Trade);
                }
                else
                {
                    result = PlaceLimitOrder(
                        plan.Direction,
                        SymbolName,
                        plan.VolumeInUnits,
                        plan.EntryPrice,
                        plan.Label,
                        DoNotApplyStopLoss ? null : (double?)plan.StopLossPips,
                        DoNotApplyTakeProfit ? null : (double?)plan.TakeProfitPips,
                        ProtectionType.Relative,
                        GetExpiry(),
                        plan.Comment,
                        false);
                }
            }
            else if (plan.EntryMode == EntryMode.StopLimit)
            {
                result = PlaceStopLimitOrder(
                    plan.Direction,
                    SymbolName,
                    plan.VolumeInUnits,
                    plan.EntryPrice,
                    plan.StopLimitRangePips,
                    plan.Label,
                    DoNotApplyStopLoss ? null : (double?)plan.StopLossPips,
                    DoNotApplyTakeProfit ? null : (double?)plan.TakeProfitPips,
                    ProtectionType.Relative,
                    GetExpiry(),
                    plan.Comment,
                    false,
                    StopTriggerMethod.Trade);
            }

            if (result == null)
            {
                if (_statusText != null)
                    _statusText.Text = "Status: no trade result";
                return;
            }

            if (result.IsSuccessful)
            {
                Print("Trade successful.");
                if (_statusText != null)
                    _statusText.Text = "Status: trade successful";
            }
            else
            {
                Print("Trade failed: {0}", result.Error);
                if (_statusText != null)
                    _statusText.Text = $"Status: failed - {result.Error}";
            }
        }

        private DateTime? GetExpiry()
        {
            if (ExpiryMinutes <= 0)
                return null;

            return Server.Time.AddMinutes(ExpiryMinutes);
        }

        private TradeType InferDirection()
        {
            return _slPrice < _entryPrice ? TradeType.Buy : TradeType.Sell;
        }

        private double GetRiskAmount()
        {
            if (_panelMoneyRisk > 0)
                return _panelMoneyRisk;

            return Account.Balance * (_panelRiskPercent / 100.0);
        }

        private double GetSlPips()
        {
            return Math.Abs(_entryPrice - _slPrice) / Symbol.PipSize;
        }

        private double GetTpPips()
        {
            return Math.Abs(_tpPrice - _entryPrice) / Symbol.PipSize;
        }

        private double CalculateVolumeInUnits(double riskAmount, double slPips)
        {
            if (slPips <= 0 || riskAmount <= 0)
                return 0;

            var pipValuePerUnit = Symbol.PipValue;
            if (pipValuePerUnit <= 0)
                return 0;

            var effectivePips = slPips;

            if (_panelIncludeSpread)
                effectivePips += Symbol.Spread / Symbol.PipSize;

            var commissionPerUnit = 0.0;
            if (_panelIncludeCommission && _panelCommissionPerLot > 0)
                commissionPerUnit = _panelCommissionPerLot / Symbol.LotSize;

            var costPerUnit = (effectivePips * pipValuePerUnit) + commissionPerUnit;
            if (costPerUnit <= 0)
                return 0;

            var rawUnits = riskAmount / costPerUnit;
            return Symbol.NormalizeVolumeInUnits(rawUnits, RoundingMode.Down);
        }

        private double NormalizePrice(double price)
        {
            return Math.Round(price, Symbol.Digits, MidpointRounding.AwayFromZero);
        }

        private string FormatPrice(double price)
        {
            return price.ToString("F" + Symbol.Digits, CultureInfo.InvariantCulture);
        }

        private class TradePlan
        {
            public TradeType Direction { get; set; }
            public EntryMode EntryMode { get; set; }
            public double EntryPrice { get; set; }
            public double StopLossPrice { get; set; }
            public double TakeProfitPrice { get; set; }
            public double StopLossPips { get; set; }
            public double TakeProfitPips { get; set; }
            public double StopLimitRangePips { get; set; }
            public double RiskAmount { get; set; }
            public double VolumeInUnits { get; set; }
            public string Label { get; set; }
            public string Comment { get; set; }
        }
    }
